generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Roles enum
enum Role {
  ADMIN
  VERTRIEB
  PROJEKTLEITUNG
  BUCHHALTUNG
  GESCHAEFTSLEITUNG
}

// Lead source enum
enum LeadSource {
  HOMEPAGE
  LANDINGPAGE
  MESSE
  EMPFEHLUNG
  KALTAKQUISE
  SONSTIGE
}

// Lead status enum
enum LeadStatus {
  ACTIVE
  CONVERTED
  LOST
  ARCHIVED
}

// Deal status enum
enum DealStatus {
  OPEN
  WON
  LOST
}

// Appointment type enum
enum AppointmentType {
  ONLINE
  VOR_ORT
}

// Order status enum
enum OrderStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Task priority enum
enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

// Task status enum
enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  role        Role      @default(VERTRIEB)
  avatarColor String?   @map("avatar_color")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  leads       Lead[]    @relation("AssignedLeads")
  deals       Deal[]    @relation("AssignedDeals")
  tasks       Task[]    @relation("AssignedTasks")
  auditLogs   AuditLog[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Pipeline {
  id         String    @id @default(uuid())
  name       String
  type       String    @default("lead") // "lead" or "deal"
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  buckets    Bucket[]
  leads      Lead[]

  @@map("pipelines")
}

model Bucket {
  id         String    @id @default(uuid())
  name       String
  pipelineId String    @map("pipeline_id")
  sortOrder  Int       @default(0) @map("sort_order")
  color      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id])
  leads      Lead[]
  deals      Deal[]

  @@map("buckets")
}

model Tag {
  id         String    @id @default(uuid())
  name       String    @unique
  color      String?
  createdAt  DateTime  @default(now()) @map("created_at")

  leads      LeadTag[]

  @@map("tags")
}

model Lead {
  id          String      @id @default(uuid())
  firstName   String?     @map("first_name")
  lastName    String?     @map("last_name")
  company     String?
  address     String
  phone       String
  email       String
  source      LeadSource
  pipelineId  String?     @map("pipeline_id")
  bucketId    String?     @map("bucket_id")
  assignedTo  String?     @map("assigned_to")
  aiSummary   String?     @map("ai_summary")
  status      LeadStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  pipeline    Pipeline?   @relation(fields: [pipelineId], references: [id])
  bucket      Bucket?     @relation(fields: [bucketId], references: [id])
  assignee    User?       @relation("AssignedLeads", fields: [assignedTo], references: [id])
  tags        LeadTag[]
  deals       Deal[]
  tasks       Task[]      @relation("LeadTasks")

  @@map("leads")
}

model LeadTag {
  leadId     String   @map("lead_id")
  tagId      String   @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")

  lead       Lead     @relation(fields: [leadId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@id([leadId, tagId])
  @@map("lead_tags")
}

model Deal {
  id                String          @id @default(uuid())
  title             String
  leadId            String?         @map("lead_id")
  assignedTo        String?         @map("assigned_to")
  bucketId          String?         @map("bucket_id")
  appointmentType   AppointmentType @map("appointment_type")
  dealValue         Decimal?        @map("deal_value")
  margin            Decimal?
  marginPercent     Decimal?        @map("margin_percent")
  expectedCloseDate DateTime?       @map("expected_close_date")
  aiSummary         String?         @map("ai_summary")
  status            DealStatus      @default(OPEN)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  lead              Lead?           @relation(fields: [leadId], references: [id])
  assignee          User?           @relation("AssignedDeals", fields: [assignedTo], references: [id])
  bucket            Bucket?         @relation(fields: [bucketId], references: [id])
  order             Order?
  tasks             Task[]          @relation("DealTasks")

  @@map("deals")
}

model Partner {
  id              String    @id @default(uuid())
  name            String
  contactPerson   String?   @map("contact_person")
  email           String?
  phone           String?
  avgRating       Decimal?  @map("avg_rating")
  totalProjects   Int       @default(0) @map("total_projects")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  orders          Order[]

  @@map("partners")
}

model Order {
  id              String      @id @default(uuid())
  dealId          String      @unique @map("deal_id")
  partnerId       String?     @map("partner_id")
  plannedCosts    Decimal?    @map("planned_costs")
  actualCosts     Decimal?    @map("actual_costs")
  customerRating  Int?        @map("customer_rating")
  customerComment String?     @map("customer_comment")
  status          OrderStatus @default(IN_PROGRESS)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  deal            Deal        @relation(fields: [dealId], references: [id])
  partner         Partner?    @relation(fields: [partnerId], references: [id])
  tasks           Task[]      @relation("OrderTasks")

  @@map("orders")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  dueDate     DateTime?    @map("due_date")
  assignedTo  String?      @map("assigned_to")
  leadId      String?      @map("lead_id")
  dealId      String?      @map("deal_id")
  orderId     String?      @map("order_id")
  isAutomatic Boolean      @default(false) @map("is_automatic")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  assignee    User?        @relation("AssignedTasks", fields: [assignedTo], references: [id])
  lead        Lead?        @relation("LeadTasks", fields: [leadId], references: [id])
  deal        Deal?        @relation("DealTasks", fields: [dealId], references: [id])
  order       Order?       @relation("OrderTasks", fields: [orderId], references: [id])

  @@map("tasks")
}

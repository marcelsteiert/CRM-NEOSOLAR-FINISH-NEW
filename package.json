{
  "name": "crm-neosolar",
  "version": "0.1.0",
  "private": true,
  "description": "NeoSolar PV-CRM/ERP – Vertikal integriertes Betriebssystem",
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "lint": "npm run lint --workspace=client && npm run lint --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.2"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ]
}
